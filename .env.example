# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Every collector reads BOTH its API key and its pinned model string from here.
# Model strings are pins for reproducibility — record them; never hardcode in code.
# Recommended models below are sane defaults as of early 2026 — confirm with
# `python -m collect.test_connection`, which validates each against the live API.

# --- OpenAI (ChatGPT) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google Gemini (AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Perplexity (Sonar) ---
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# --- Google AI Overviews via SerpApi (no public API for AIO) ---
SERPAPI_API_KEY=
